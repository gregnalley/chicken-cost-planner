<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <title>Egg Profit Calculator | Backyard Chicken Egg Income & Profit Estimator</title>

    <meta name="description" content="Calculate egg profit from backyard chickens including egg production, feed costs, pricing per dozen, and monthly profit estimates. Free egg income calculator.">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 850px;
            margin: 40px auto;
            padding: 20px;
            background: #f7f9fb;
        }

        .banner {
            background: linear-gradient(90deg, #FF9800, #F57C00);
            color: white;
            padding: 25px;
            border-radius: 12px;
            text-align: center;
            margin-bottom: 20px;
        }

        .section {
            margin-top: 20px;
            padding: 18px;
            background: #ffffff;
            border: 1px solid #e6e6e6;
            border-radius: 10px;
        }

        label {
            font-weight: bold;
            display: block;
            margin-top: 12px;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            font-size: 16px;
            border: 1px solid #ddd;
            border-radius: 6px;
        }

        button {
            margin-top: 20px;
            padding: 12px;
            width: 100%;
            background: #FF9800;
            color: white;
            border: none;
            font-size: 16px;
            cursor: pointer;
            border-radius: 6px;
        }

        button:hover {
            background: #F57C00;
        }

        .result {
            margin-top: 20px;
            padding: 15px;
            background: #fff;
            border-radius: 8px;
            border: 1px solid #ddd;
        }
    </style>
</head>

<body>

<div class="banner">
    <h1>🥚 Egg Profit Calculator</h1>
    <p>Estimate how much money your backyard chickens can make from egg production</p>
</div>

<div class="section">

    <label>Number of Chickens:</label>
    <input id="chickens" type="number" placeholder="e.g. 6">

    <label>Eggs per Chicken per Week:</label>
    <input id="eggsPerWeek" type="number" value="5">

    <label>Egg Price ($ per dozen):</label>
    <input id="eggPrice" type="number" value="4.00">

    <label>Feed Cost per Month ($):</label>
    <input id="feedCost" type="number" value="30">

    <label>Other Monthly Costs ($):</label>
    <input id="otherCost" type="number" value="0">

    <button onclick="calculate()">Calculate Profit</button>

    <div class="result" id="result"></div>

</div>

<script>

function calculate() {

    let chickens = parseFloat(document.getElementById("chickens").value);
    let eggsPerWeek = parseFloat(document.getElementById("eggsPerWeek").value);
    let eggPrice = parseFloat(document.getElementById("eggPrice").value);
    let feedCost = parseFloat(document.getElementById("feedCost").value);
    let otherCost = parseFloat(document.getElementById("otherCost").value);

    let eggsPerMonth = chickens * eggsPerWeek * 4;
    let dozens = eggsPerMonth / 12;

    let revenue = dozens * eggPrice;
    let totalCosts = feedCost + otherCost;

    let profit = revenue - totalCosts;

    document.getElementById("result").innerHTML = `
        🥚 Eggs per month: ${eggsPerMonth.toFixed(0)}<br>
        💰 Revenue: $${revenue.toFixed(2)}<br>
        💸 Costs: $${totalCosts.toFixed(2)}<br>
        📈 Profit: $${profit.toFixed(2)}
    `;
}

</script>

</body>
</html>
